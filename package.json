{
  "name": "@procoders/astrology-api-client",
  "version": "0.1.0",
  "description": "TypeScript SDK for interacting with the Astrology API.",
  "keywords": [
    "astrology",
    "api",
    "sdk",
    "typescript",
    "axios"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "clean": "rimraf dist",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "generate:types": "openapi-typescript docs-openapi.json --output ./src/types/generated/api.ts --export-type",
    "prepublishOnly": "npm run clean && npm run lint && npm run test:coverage && npm run build"
  },
  "dependencies": {
    "axios": "1.13.2"
  },
  "devDependencies": {
    "@types/node": "24.10.0",
    "@typescript-eslint/eslint-plugin": "8.46.4",
    "@typescript-eslint/parser": "8.46.4",
    "@vitest/coverage-v8": "4.0.8",
    "axios-mock-adapter": "2.1.0",
    "eslint": "9.39.1",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.6.2",
    "rimraf": "6.1.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "4.0.8",
    "openapi-typescript": "7.10.1"
  },
  "engines": {
    "node": ">=18.18"
  }
}
